{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "@app/account": "<rootDir>/../libs/account/src",
    "@app/account/(.*)": "<rootDir>/../libs/account/src/$1",
    "@app/auth": "<rootDir>/../libs/auth/src",
    "@app/auth/(.*)": "<rootDir>/../libs/auth/src/$1",
    "@app/configs": "<rootDir>/../libs/configs/src",
    "@app/configs/(.*)": "<rootDir>/../libs/configs/src/$1",
    "@app/shared/constants": "<rootDir>/../libs/shared/constants/src",
    "@app/shared/constants/(.*)": "<rootDir>/../libs/shared/constants/src/$1",
    "@app/shared/decorators": "<rootDir>/../libs/shared/decorators/src",
    "@app/shared/decorators/(.*)": "<rootDir>/../libs/shared/decorators/src/$1",
    "@app/shared/entities": "<rootDir>/../libs/shared/entities/src",
    "@app/shared/entities/(.*)": "<rootDir>/../libs/shared/entities/src/$1",
    "@app/shared/prisma": "<rootDir>/../libs/shared/prisma/src",
    "@app/shared/prisma/(.*)": "<rootDir>/../libs/shared/prisma/src/$1",
    "@app/shared/utils": "<rootDir>/../libs/shared/utils/src",
    "@app/shared/utils/(.*)": "<rootDir>/../libs/shared/utils/src/$1",
    "@app/tenant": "<rootDir>/../libs/tenant/src",
    "@app/tenant/(.*)": "<rootDir>/../libs/tenant/src/$1"
  }
}