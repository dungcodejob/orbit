{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "account": {
      "type": "library",
      "root": "libs/account",
      "entryFile": "index",
      "sourceRoot": "libs/account/src",
      "compilerOptions": {
        "tsConfigPath": "libs/account/tsconfig.lib.json"
      }
    },
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "configs": {
      "type": "library",
      "root": "libs/configs",
      "entryFile": "index",
      "sourceRoot": "libs/configs/src",
      "compilerOptions": {
        "tsConfigPath": "libs/configs/tsconfig.lib.json"
      }
    },
    "shared/constants": {
      "type": "library",
      "root": "libs/shared/constants",
      "entryFile": "index",
      "sourceRoot": "libs/shared/constants/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/constants/tsconfig.lib.json"
      }
    },
    "shared/decorators": {
      "type": "library",
      "root": "libs/shared/decorators",
      "entryFile": "index",
      "sourceRoot": "libs/shared/decorators/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/decorators/tsconfig.lib.json"
      }
    },
    "shared/entities": {
      "type": "library",
      "root": "libs/shared/entities",
      "entryFile": "index",
      "sourceRoot": "libs/shared/entities/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/entities/tsconfig.lib.json"
      }
    },
    "shared/prisma": {
      "type": "library",
      "root": "libs/shared/prisma",
      "entryFile": "index",
      "sourceRoot": "libs/shared/prisma/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/prisma/tsconfig.lib.json"
      }
    },
    "shared/utils": {
      "type": "library",
      "root": "libs/shared/utils",
      "entryFile": "index",
      "sourceRoot": "libs/shared/utils/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/utils/tsconfig.lib.json"
      }
    },
    "tenant": {
      "type": "library",
      "root": "libs/tenant",
      "entryFile": "index",
      "sourceRoot": "libs/tenant/src",
      "compilerOptions": {
        "tsConfigPath": "libs/tenant/tsconfig.lib.json"
      }
    }
  }
}